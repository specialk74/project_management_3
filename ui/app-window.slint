component Toolbar inherits Rectangle {
    in property <AppProject> app_project;
    height: 32px;
    background: #2a2a2a;

    // State for new-project dialog
    property <string> new-proj-tripletta: "";
    property <string> new-proj-name: "Nuovo Progetto";
    property <string> new-proj-start: PjmCallback.current-week-text;
    property <length> proj-list-popup-x: 0px;
    property <length> worker-filter-popup-x: 0px;

    // Watch PjmCallback.show-worker-filter to open popup from keyboard/cell shortcuts
    property <bool> _show-wf: PjmCallback.show-worker-filter;
    changed _show-wf => {
        if (_show-wf) {
            worker-filter-popup.show();
            PjmCallback.show-worker-filter = false;
        }
    }

    new-proj-popup := PopupWindow {
        close-policy: no-auto-close;
        width: 300px;
        height: 210px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 300px;
            height: 210px;

            VerticalLayout {
                padding: Styles.padding;
                spacing: Styles.spacing;

                Text {
                    color: Colors.lightgray;
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text: "Nuovo Progetto";
                }

                proj-tripletta-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> new-proj-tripletta;
                    placeholder-text: "Tripletta (opzionale)...";
                }

                proj-name-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> new-proj-name;
                    placeholder-text: "Nome progetto...";
                }

                proj-start-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> new-proj-start;
                    placeholder-text: "Data inizio yy-mm-dd";
                }

                HorizontalLayout {
                    spacing: Styles.spacing;
                    alignment: end;

                    Button {
                        text: "OK";
                        clicked => {
                            PjmCallback.new_project(new-proj-tripletta, new-proj-name, new-proj-start);
                            new-proj-tripletta = "";
                            new-proj-name = "Nuovo Progetto";
                            new-proj-start = PjmCallback.current-week-text;
                            new-proj-popup.close();
                        }
                    }

                    Button {
                        text: "Annulla";
                        clicked => {
                            new-proj-tripletta = "";
                            new-proj-name = "Nuovo Progetto";
                            new-proj-start = PjmCallback.current-week-text;
                            new-proj-popup.close();
                        }
                    }
                }
            }
        }
    }

    proj-list-popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: root.proj-list-popup-x;
        y: root.height;
        width: 160px;
        height: 300px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 160px;
            height: 300px;

            VerticalLayout {
                x: 1px;
                y: 1px;
                width: parent.width - 2px;
                height: parent.height - 2px;
                spacing: 0px;
                padding: 0px;

                // Select All row
                Rectangle {
                    height: 26px;
                    background: select-all-ta.has-hover ? #2a2a2a : Colors.transparent;

                    cb-select-all := Rectangle {
                        x: 6px;
                        y: (parent.height - 13px) / 2;
                        width: 13px;
                        height: 13px;
                        border-width: 1px;
                        border-color: #888888;
                        border-radius: 2px;
                        background: PjmCallback.all_projects_enabled ? #4a90d9 : Colors.transparent;

                        Text {
                            visible: PjmCallback.all_projects_enabled;
                            text: "✓";
                            font-size: 9px;
                            color: Colors.white;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Text {
                        x: cb-select-all.x + cb-select-all.width + 6px;
                        y: 0px;
                        width: parent.width - cb-select-all.x - cb-select-all.width - 10px;
                        height: parent.height;
                        text: "Select All";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    select-all-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_all_projects_enabled(true);
                        }
                    }
                }

                // Deselect All row
                Rectangle {
                    height: 26px;
                    background: deselect-all-ta.has-hover ? #2a2a2a : Colors.transparent;

                    cb-deselect-all := Rectangle {
                        x: 6px;
                        y: (parent.height - 13px) / 2;
                        width: 13px;
                        height: 13px;
                        border-width: 1px;
                        border-color: #888888;
                        border-radius: 2px;
                        background: PjmCallback.all_projects_disabled ? #4a90d9 : Colors.transparent;

                        Text {
                            visible: PjmCallback.all_projects_disabled;
                            text: "✓";
                            font-size: 9px;
                            color: Colors.white;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Text {
                        x: cb-deselect-all.x + cb-deselect-all.width + 6px;
                        y: 0px;
                        width: parent.width - cb-deselect-all.x - cb-deselect-all.width - 10px;
                        height: parent.height;
                        text: "Deselect All";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    deselect-all-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_all_projects_enabled(false);
                        }
                    }
                }

                // Project list
                ListView {
                    for project in root.app_project.projects: Rectangle {
                        height: 26px;
                        background: row-ta.has-hover ? #2a2a2a : Colors.transparent;

                        cb := Rectangle {
                            x: 6px;
                            y: (parent.height - 13px) / 2;
                            width: 13px;
                            height: 13px;
                            border-width: 1px;
                            border-color: #888888;
                            border-radius: 2px;
                            background: project.enable ? #4a90d9 : Colors.transparent;

                            Text {
                                visible: project.enable;
                                text: "✓";
                                font-size: 9px;
                                color: Colors.white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }

                        Text {
                            x: cb.x + cb.width + 6px;
                            y: 0px;
                            width: parent.width - cb.x - cb.width - 10px;
                            height: parent.height;
                            text: project.tripletta == "" ? "\{project.project_id}" : "\{project.project_id} \{project.tripletta}";
                            color: project.enable ? Colors.lightgray : #666666;
                            font-family: Styles.font-family;
                            font-size: Styles.font-size;
                            vertical-alignment: center;
                        }

                        row-ta := TouchArea {
                            clicked => {
                                PjmCallback.set_project_enabled(project.project_id, !project.enable);
                            }
                        }
                    }
                }
            }
        }
    }

    worker-filter-popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: root.worker-filter-popup-x;
        y: root.height;
        width: 180px;
        height: 300px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 180px;
            height: 300px;

            VerticalLayout {
                x: 1px;
                y: 1px;
                width: parent.width - 2px;
                height: parent.height - 2px;
                spacing: 0px;
                padding: 0px;

                // Seleziona tutti
                Rectangle {
                    height: 26px;
                    background: seleziona-ta.has-hover ? #2a2a2a : Colors.transparent;

                    cb-seleziona := Rectangle {
                        x: 6px;
                        y: (parent.height - 13px) / 2;
                        width: 13px;
                        height: 13px;
                        border-width: 1px;
                        border-color: #888888;
                        border-radius: 2px;
                        background: PjmCallback.all_workers_filter_on ? #4a90d9 : Colors.transparent;

                        Text {
                            visible: PjmCallback.all_workers_filter_on;
                            text: "✓";
                            font-size: 9px;
                            color: Colors.white;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Text {
                        x: cb-seleziona.x + cb-seleziona.width + 6px;
                        y: 0px;
                        width: parent.width - cb-seleziona.x - cb-seleziona.width - 10px;
                        height: parent.height;
                        text: "Seleziona tutti";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    seleziona-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_all_workers_filter(true);
                        }
                    }
                }

                // Deseleziona tutti
                Rectangle {
                    height: 26px;
                    background: deseleziona-ta.has-hover ? #2a2a2a : Colors.transparent;

                    cb-deseleziona := Rectangle {
                        x: 6px;
                        y: (parent.height - 13px) / 2;
                        width: 13px;
                        height: 13px;
                        border-width: 1px;
                        border-color: #888888;
                        border-radius: 2px;
                        background: PjmCallback.all_workers_filter_off ? #4a90d9 : Colors.transparent;

                        Text {
                            visible: PjmCallback.all_workers_filter_off;
                            text: "✓";
                            font-size: 9px;
                            color: Colors.white;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Text {
                        x: cb-deseleziona.x + cb-deseleziona.width + 6px;
                        y: 0px;
                        width: parent.width - cb-deseleziona.x - cb-deseleziona.width - 10px;
                        height: parent.height;
                        text: "Deseleziona tutti";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    deseleziona-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_all_workers_filter(false);
                        }
                    }
                }

                // Lista workers
                ListView {
                    for worker[idx] in root.app_project.worker_names: Rectangle {
                        height: 26px;
                        background: worker-ta.has-hover ? #2a2a2a : Colors.transparent;

                        cb-worker := Rectangle {
                            x: 6px;
                            y: (parent.height - 13px) / 2;
                            width: 13px;
                            height: 13px;
                            border-width: 1px;
                            border-color: #888888;
                            border-radius: 2px;
                            background: root.app_project.worker_filter_selected[idx] ? #4a90d9 : Colors.transparent;

                            Text {
                                visible: root.app_project.worker_filter_selected[idx];
                                text: "✓";
                                font-size: 9px;
                                color: Colors.white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }

                        Text {
                            x: cb-worker.x + cb-worker.width + 6px;
                            y: 0px;
                            width: parent.width - cb-worker.x - cb-worker.width - 10px;
                            height: parent.height;
                            text: worker;
                            color: root.app_project.worker_filter_selected[idx] ? Colors.lightgray : #666666;
                            font-family: Styles.font-family;
                            font-size: Styles.font-size;
                            vertical-alignment: center;
                        }

                        worker-ta := TouchArea {
                            clicked => {
                                PjmCallback.set_worker_filter(idx, !root.app_project.worker_filter_selected[idx]);
                            }
                        }
                    }
                }
            }
        }
    }

    HorizontalLayout {
        spacing: 4px;
        padding-left: 6px;
        padding-right: 6px;
        alignment: start;

        Button {
            text: "+ Progetto";
            height: 26px;
            clicked => {
                new-proj-name = "Nuovo Progetto";
                new-proj-start = PjmCallback.current-week-text;
                new-proj-popup.show();
            }
        }

        btn-progetti := Button {
            text: "Progetti ▼";
            height: 26px;
            clicked => {
                root.proj-list-popup-x = self.absolute-position.x - root.absolute-position.x;
                proj-list-popup.show();
            }
        }

        btn-workers := Button {
            text: "Workers ▼";
            height: 26px;
            clicked => {
                root.worker-filter-popup-x = self.absolute-position.x - root.absolute-position.x;
                worker-filter-popup.show();
            }
        }

        Rectangle {
            width: 8px;
        }

        worker-input := LineEdit {
            placeholder-text: "Nome worker…";
            width: 130px;
            height: 26px;
            accepted => {
                if (self.text != "") {
                    PjmCallback.add_worker(self.text);
                    self.text = "";
                }
            }
        }

        Button {
            text: "+ Worker";
            height: 26px;
            clicked => {
                if (worker-input.text != "") {
                    PjmCallback.add_worker(worker-input.text);
                    worker-input.text = "";
                }
            }
        }

        Rectangle {
            width: 8px;
        }

        dev-input := LineEdit {
            placeholder-text: "Nome dev…";
            width: 130px;
            height: 26px;
            accepted => {
                if (self.text != "") {
                    PjmCallback.add_dev(self.text);
                    self.text = "";
                }
            }
        }

        Button {
            text: "+ Dev";
            height: 26px;
            clicked => {
                if (dev-input.text != "") {
                    PjmCallback.add_dev(dev-input.text);
                    dev-input.text = "";
                }
            }
        }

        Rectangle {
            width: 8px;
        }

        cat-input := LineEdit {
            placeholder-text: "Nome categoria…";
            width: 130px;
            height: 26px;
            accepted => {
                if (self.text != "") {
                    PjmCallback.add_category(self.text);
                    self.text = "";
                }
            }
        }

        Button {
            text: "+ Project Category";
            height: 26px;
            clicked => {
                if (cat-input.text != "") {
                    PjmCallback.add_category(cat-input.text);
                    cat-input.text = "";
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Text {
            text: PjmCallback.current_file;
            color: PjmCallback.changed ? Colors.orange : Colors.gray;
            vertical-alignment: center;
            font-size: 11px;
        }

        Rectangle {
            width: 6px;
        }

        Button {
            text: "Salva";
            height: 26px;
            clicked => {
                PjmCallback.save_file();
            }
        }

        Button {
            text: "Apri";
            height: 26px;
            clicked => {
                PjmCallback.open_file();
            }
        }

        Button {
            text: PjmCallback.compact-mode ? "Vista normale" : "Vista compatta";
            height: 26px;
            clicked => {
                PjmCallback.compact-mode = !PjmCallback.compact-mode;
            }
        }
    }
}

export component AppWindow inherits Window {
    in-out property <AppProject> app_project;
    in property <int> num_visible: 1;
    in property <bool> loading: true;
    property <length> viewport_y;
    in-out property <length> viewport_x;
    property <length> width1: 150px;
    in property <[DayData]> weeks;

    forward-focus: fs;

    default-font-size: Styles.font-size;
    default-font-family: Styles.font-family;
    title: "Project Management Effort Tracker App [" + PjmCallback.current_file + "]" + (PjmCallback.changed ? " (*)" : "");
    min-width: 1024px;
    min-height: 768px;
    resize-border-width: 10px;
    full-screen: false;

    VerticalLayout {
        Toolbar {
            app_project: root.app_project;
        }

        Header {
            weeks: root.weeks;
            viewport_x <=> root.viewport_x;
            app_project: root.app_project;
        }

        Rectangle {
            height: self.visible ? Styles.dev-border : 0px;
            background: Styles.color-start-stop;
        }

        Rectangle {
            vertical-stretch: 100;
            HorizontalLayout {
                LeftColumn {
                    app_project: root.app_project;

                    // binding verticale
                viewport_y <=> root.viewport_y;
                }

                RightColumn {
                    app_project: root.app_project;

                    viewport_y <=> root.viewport_y;
                    viewport_x <=> root.viewport_x;
                }

                spacing: 0px;
                padding: 0px;
            }
        }

        Rectangle {
            visible: !PjmCallback.compact-mode;
            height: self.visible ? Styles.dev-border : 0px;
            background: Styles.color-start-stop;
        }

        Header {
            visible: !PjmCallback.compact-mode;
            weeks: root.weeks;
            viewport_x <=> root.viewport_x;
            app_project: root.app_project;
        }

        HorizontalLayout {
            visible: !PjmCallback.compact-mode;
            LeftFooter {
                app_project: root.app_project;
            }

            RightFooter {
                app_project: root.app_project;
                viewport_x <=> root.viewport_x;
            }
        }
    }

    if PjmCallback.note-popup-visible: Rectangle {
        x: PjmCallback.note-popup-x;
        y: PjmCallback.note-popup-y;
        width: 200px;
        height: note-tooltip-text.preferred-height + 12px;
        background: #fffde7;
        border-color: Styles.note-color;
        border-width: 1px;
        z: 1000;

        note-tooltip-text := Text {
            x: 6px;
            y: 6px;
            width: 188px;
            text: PjmCallback.note-popup-text;
            wrap: word-wrap;
            color: Colors.black;
            font-size: Styles.font-size;
            font-family: Styles.font-family;
        }
    }

    // Unica istanza globale del note editor (sostituisce le N istanze in EffortByDataGui)
    global-note-editor := NoteEditorWindow {
        visible: false;
        container-width: root.width;
        container-height: root.height;
        property <bool> _trigger: PjmCallback.note-editor-active;
        changed _trigger => {
            if (_trigger) {
                if (PjmCallback.note-editor-is-dev) {
                    self.show-for-dev(
                        PjmCallback.note-editor-project,
                        PjmCallback.note-editor-dev,
                        PjmCallback.note-editor-text);
                } else {
                    self.show-for-effort(
                        PjmCallback.note-editor-project,
                        PjmCallback.note-editor-dev,
                        PjmCallback.note-editor-week,
                        PjmCallback.note-editor-worker,
                        PjmCallback.note-editor-text);
                }
                PjmCallback.note-editor-active = false;
            }
        }
    }

    if PjmCallback.editor-active: Rectangle {
        x: PjmCallback.editor-x;
        y: PjmCallback.editor-y;
        z: 999;
        width: Styles.width;
        height: Styles.height;
        background: Colors.transparent;

        property <string> typed_prefix: PjmCallback.editor-typed-prefix;

        init => {
            floating-le.focus();
            floating-le.set-selection-offsets(PjmCallback.editor-text.character-count, PjmCallback.editor-text.character-count);
        }

        floating-le := LineEdit {
            height: 100%;
            width: 100%;
            text <=> PjmCallback.editor-text;

            key-pressed(event) => {
                if event.text == Key.Backspace || event.text == Key.Delete {
                    typed_prefix = PjmCallback.remove_last_char(typed_prefix);
                    PjmCallback.editor-text = PjmCallback.find_completion(typed_prefix, true);
                    if PjmCallback.editor-text == "" {
                        PjmCallback.editor-text = typed_prefix;
                    } else {
                        typed_prefix = PjmCallback.editor-text;
                    }
                    self.set-selection-offsets(PjmCallback.editor-text.character-count, PjmCallback.editor-text.character-count);
                    return accept;
                }
                if event.text == Key.Escape {
                    PjmCallback.editor-active = false;
                    return accept;
                }
                if event.text == Key.Return || event.text == Key.Shift || event.text == Key.ShiftR {
                    return reject;
                }
                if event.modifiers.control {
                    if event.text == "S" || event.text == "s" {
                        PjmCallback.editor-accept();
                        PjmCallback.save_file();
                        return accept;
                    }
                    if event.text == "C" || event.text == "c" {
                        PjmCallback.testo-copiato = PjmCallback.editor-text;
                        return accept;
                    }
                    if event.text == "V" || event.text == "v" {
                        PjmCallback.editor-text = PjmCallback.testo-copiato;
                        typed_prefix = PjmCallback.editor-text;
                        self.set-selection-offsets(PjmCallback.editor-text.character-count, PjmCallback.editor-text.character-count);
                        return accept;
                    }
                    if event.text == "f" {
                        PjmCallback.editor-active = false;
                        PjmCallback.show-worker-filter = true;
                        return accept;
                    }
                    if event.text == "F" {
                        PjmCallback.editor-active = false;
                        PjmCallback.set_all_workers_filter(false);
                        return accept;
                    }
                    return reject;
                }
                if event.modifiers.alt || event.modifiers.meta {
                    return reject;
                }
                if event.text == "" {
                    return reject;
                }
                if event.text == Key.Tab {
                    PjmCallback.editor-accept();
                    return accept;
                }
                typed_prefix += event.text;
                PjmCallback.editor-text = PjmCallback.find_completion(typed_prefix, true);
                if PjmCallback.editor-text == "" {
                    PjmCallback.editor-text = typed_prefix;
                } else {
                    typed_prefix = PjmCallback.editor-text;
                }
                self.set-selection-offsets(PjmCallback.editor-text.character-count, PjmCallback.editor-text.character-count);
                accept
            }

            accepted => {
                PjmCallback.editor-accept();
            }
        }
    }

    fs := FocusScope {
        init => {
            self.focus();
        }
        key-pressed(event) => {
            if (event.modifiers.control) {
                if (event.text == "S" || event.text == "s") {
                    PjmCallback.save_file();
                    return accept;
                }
                if (event.text == "f") {
                    PjmCallback.show-worker-filter = true;
                    return accept;
                }
                if (event.text == "F") {
                    PjmCallback.set_all_workers_filter(false);
                    return accept;
                }
                if (event.text == "N" || event.text == "n") {
                    PjmCallback.new_project("", "Nuovo Progetto", "");
                    return accept;
                }
                if (event.text == "O" || event.text == "o") {
                    PjmCallback.open_file();
                    return accept;
                }
            }
            reject
        }
    }

    Timer {
        interval: 5000ms;
        running: true;
        triggered => {
            PjmCallback.marquee-tick += 1;
        }
    }
}
