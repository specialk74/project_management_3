component Toolbar inherits Rectangle {
    height: 32px;
    background: #2a2a2a;

    HorizontalLayout {
        spacing: 4px;
        padding-left: 6px;
        padding-right: 6px;
        alignment: start;

        Button {
            text: "+ Progetto";
            height: 26px;
            clicked => {
                PjmCallback.new_project();
            }
        }

        Rectangle {
            width: 8px;
        }

        worker-input := LineEdit {
            placeholder-text: "Nome worker…";
            width: 130px;
            height: 26px;
            accepted => {
                if (self.text != "") {
                    PjmCallback.add_worker(self.text);
                    self.text = "";
                }
            }
        }

        Button {
            text: "+ Worker";
            height: 26px;
            clicked => {
                if (worker-input.text != "") {
                    PjmCallback.add_worker(worker-input.text);
                    worker-input.text = "";
                }
            }
        }

        Rectangle {
            width: 8px;
        }

        dev-input := LineEdit {
            placeholder-text: "Nome dev…";
            width: 130px;
            height: 26px;
            accepted => {
                if (self.text != "") {
                    PjmCallback.add_dev(self.text);
                    self.text = "";
                }
            }
        }

        Button {
            text: "+ Dev";
            height: 26px;
            clicked => {
                if (dev-input.text != "") {
                    PjmCallback.add_dev(dev-input.text);
                    dev-input.text = "";
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Text {
            text: PjmCallback.current_file;
            color: PjmCallback.changed ? Colors.orange : Colors.gray;
            vertical-alignment: center;
            font-size: 11px;
        }

        Rectangle {
            width: 6px;
        }

        Button {
            text: "Salva";
            height: 26px;
            clicked => {
                PjmCallback.save_file();
            }
        }

        Button {
            text: "Apri";
            height: 26px;
            clicked => {
                PjmCallback.open_file();
            }
        }
    }
}

export component AppWindow inherits Window {
    in-out property <AppProject> app_project;
    in property <int> num_visible: 1;
    in property <bool> loading: true;
    property <length> viewport_y;
    property <length> viewport_x;
    property <length> width1: 150px;
    in property <[DayData]> weeks;

    default-font-size: Styles.font-size;
    default-font-family: Styles.font-family;
    title: "Project Management Effort Tracker App [" + PjmCallback.current_file + "]" + (PjmCallback.changed ? " (*)" : "");
    min-width: 1024px;
    min-height: 768px;
    resize-border-width: 10px;
    full-screen: false;

    VerticalLayout {
        Toolbar { }

        Header {
            weeks: root.weeks;
            viewport_x <=> root.viewport_x;
            app_project: root.app_project;
        }

        Rectangle {
            height: 2px;
            background: Colors.yellow;
        }

        Rectangle {
            vertical-stretch: 100;
            HorizontalLayout {
                LeftColumn {
                    app_project: root.app_project;

                    // binding verticale
                viewport_y <=> root.viewport_y;
                }

                RightColumn {
                    app_project: root.app_project;

                    viewport_y <=> root.viewport_y;
                    viewport_x <=> root.viewport_x;
                }

                spacing: 0px;
                padding: 0px;
            }
        }

        Rectangle {
            height: 2px;
            background: Colors.yellow;
        }

        Header {
            weeks: root.weeks;
            viewport_x <=> root.viewport_x;
            app_project: root.app_project;
        }

        HorizontalLayout {
            LeftFooter {
                app_project: root.app_project;
            }

            RightFooter {
                app_project: root.app_project;
                viewport_x <=> root.viewport_x;
            }
        }
    }

    fs := FocusScope {
        key-pressed(event) => {
            if (event.modifiers.control) {
                if (event.text == "S" || event.text == "s") {
                    PjmCallback.save_file();
                    return accept;
                }
                if (event.text == "f") {
                    //PjmCallback.show_modal = true;
                    //im.select_all();
                    //im.focus();
                    im.show();
                    return accept;
                }
                if (event.text == "F") {
                    PjmCallback.last-search = "";
                    PjmCallback.search("");
                    return accept;
                }
                if (event.text == "N" || event.text == "n") {
                    PjmCallback.new_project();
                    return accept;
                }
                if (event.text == "O" || event.text == "o") {
                    PjmCallback.open_file();
                    return accept;
                }
            }
            reject
        }
    }

    im := PopupWindow {
        in-out property <string> text;
        property <string> typed_prefix: "";

        init => {
            le.focus();
        }
        Rectangle {
            background: Colors.antiquewhite;
            VerticalLayout {
                Text {
                    color: Colors.blue;
                    text: "Search the worker...";
                }

                le := LineEdit {
                    text: text;
                    key-pressed(event) => {
                        if event.text == Key.Backspace || event.text == Key.Delete {
                            typed_prefix = PjmCallback.remove_last_char(typed_prefix);
                            text = PjmCallback.find_completion(typed_prefix, false);
                            if text == "" {
                                text = typed_prefix;
                            } else {
                                typed_prefix = text;
                            }
                            self.set-selection-offsets(text.character-count, text.character-count);
                            return accept;
                        }
                        if event.text == Key.Escape || event.text == Key.Return || event.text == Key.Tab || event.text == Key.Shift || event.text == Key.ShiftR {
                            return reject;
                        }
                        if event.modifiers.control || event.modifiers.alt || event.modifiers.meta {
                            return reject;
                        }
                        if event.text == "" {
                            return reject;
                        }
                        typed_prefix += event.text;
                        text = PjmCallback.find_completion(typed_prefix, false);
                        if text == "" {
                            text = typed_prefix;
                        } else {
                            typed_prefix = text;
                        }
                        self.set-selection-offsets(text.character-count, text.character-count);
                        accept
                    }
                    accepted => {
                        PjmCallback.last-search = text;
                        PjmCallback.search(text);
                        im.close();
                    }
                }

                HorizontalLayout {
                    Button {
                        text: "Search";
                        clicked => {
                            PjmCallback.last-search = text;
                            PjmCallback.search(text);
                            im.close();
                        }
                    }

                    Button {
                        text: "Abort";
                        clicked => {
                            im.close();
                        }
                    }
                }
            }
        }
    }
}
