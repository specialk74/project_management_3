import {
    Button,
    VerticalBox,
    ListView,
    CheckBox,
    LineEdit,
    Spinner,
    TextEdit,
    HorizontalBox,
    ProgressIndicator,
} from "std-widgets.slint";

import {
    EffortByPrjData,
    PjmCallback,
    AppProject,
    DevInfo,
    NoteEditorWindow,
    CornerTriangle,
} from "global.slint";
import { Styles } from "styles.slint";

component Separatore inherits Rectangle {
    in property <color> bgcolor;

    height: self.visible == false ? 0px : 1px;
    background: bgcolor;
}

component DevSelectPopup inherits Window {
    in property <[DevInfo]> devs;
    in-out property <int> project;
    in-out property <bool> add;
    in-out property <[bool]> dev-in-project: [];
    in-out property <[bool]> dev-has-data: [];

    callback confirm-remove(int /*project*/, int /*dev-idx*/);

    public function show(project: int, add: bool, in-proj: [bool], has-data: [bool]) {
        root.add = add;
        root.project = project;
        root.dev-in-project = in-proj;
        root.dev-has-data = has-data;
        popup.show();
    }

    popup := PopupWindow {
        close-policy: close-on-click-outside;
        width: 140px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555;
            border-width: 1px;

            VerticalLayout {
                padding: 2px;
                spacing: 1px;

                for dev[dev-idx] in root.devs: Rectangle {
                    visible: root.add ? (dev-idx < root.dev-in-project.length && !root.dev-in-project[dev-idx]) : (dev-idx < root.dev-in-project.length && root.dev-in-project[dev-idx]);
                    height: self.visible ? Styles.height : 0px;
                    background: dev.col;
                    border-radius: 2px;

                    Text {
                        color: dev.text-color;
                        text: dev.title;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            if root.add {
                                PjmCallback.add_dev_to_project(root.project, dev-idx, true);
                                popup.close();
                            } else if dev-idx < root.dev-has-data.length && root.dev-has-data[dev-idx] {
                                root.confirm-remove(root.project, dev-idx);
                                popup.close();
                            } else {
                                PjmCallback.add_dev_to_project(root.project, dev-idx, false);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

component Devmenu inherits Window {
    in-out property <int> project;
    in-out property <int> dev;
    in-out property <bool> enable;
    in-out property <string> dev-note: "";
    callback request-note-edit(int /*project*/, int /*dev*/, string /*current-note*/);

    public function show(project: int, dev: int, enable: bool, note: string) {
        popup.show();
        root.project = project;
        root.dev = dev;
        root.enable = enable;
        root.dev-note = note;
    }
    popup := PopupWindow {
        VerticalLayout {
            Rectangle {
                visible: !root.enable;
                background: Colors.grey;
                Text {
                    text: "Add Row";
                }

                TouchArea {
                    clicked => {
                        PjmCallback.add_row(root.project, root.dev);
                        popup.close();
                    }
                }
            }

            Rectangle {
                visible: !root.enable;
                background: Colors.grey;
                Text {
                    text: "Del Row";
                }

                TouchArea {
                    clicked => {
                        PjmCallback.del_row(root.project, root.dev);
                        popup.close();
                    }
                }
            }

            Rectangle {
                background: Colors.grey;
                Text {
                    text: "Nota Dev...";
                }

                TouchArea {
                    clicked => {
                        root.request-note-edit(root.project, root.dev, root.dev-note);
                        popup.close();
                    }
                }
            }

            // Rectangle {
            //     background: Colors.grey;
            //     Text {
            //         text: root.enable ? "Show Dev" : "Hide Dev";
            //     }

            //     TouchArea {
            //         clicked => {
            //             PjmCallback.hide_dev(root.project, root.dev, root.enable);
            //             popup.close();
            //         }
            //     }
            // }
        }

        x: 20px;
        y: 20px;
        close-policy: close-on-click-outside;
    }
}

export component LeftColumn inherits Rectangle {
    in property <AppProject> app_project;
    in-out property <length> viewport_y;

    width: Styles.left-column-width;

    // State for start week editor popup
    property <int> editing-start-proj-idx: -1;
    property <string> editing-start-text: "";
    property <length> start-popup-x: 0px;
    property <length> start-popup-y: 0px;

    // State for deadline editor popup
    property <int> editing-proj-idx: -1;
    property <string> editing-deadline-text: "";
    property <length> deadline-popup-x: 0px;
    property <length> deadline-popup-y: 0px;

    // State for tripletta editor popup
    property <int> editing-tripletta-proj-idx: -1;
    property <string> editing-tripletta-text: "";
    property <length> tripletta-popup-x: 0px;
    property <length> tripletta-popup-y: 0px;

    // State for dev removal confirmation
    property <int> confirm-dev-proj: -1;
    property <int> confirm-dev-idx: -1;

    // State for effort visibility menu
    property <int> effort-menu-proj: -1;
    property <int> effort-menu-dev: -1;
    property <length> effort-menu-x: 0px;
    property <length> effort-menu-y: 0px;

    // State for category selector popup
    property <int> category-menu-proj-idx: -1;
    property <length> category-popup-x: 0px;
    property <length> category-popup-y: 0px;

    start-popup := PopupWindow {
        close-policy: no-auto-close;
        x: root.start-popup-x;
        y: root.start-popup-y;
        width: 260px;
        height: 130px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 260px;
            height: 130px;

            VerticalLayout {
                padding: Styles.padding;
                spacing: Styles.spacing;

                Text {
                    color: Colors.lightgray;
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text: "Data inizio progetto (yy-mm-dd)";
                }

                start-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> root.editing-start-text;
                    placeholder-text: "yy-mm-dd";
                    accepted => {
                        PjmCallback.set_project_start_week(root.editing-start-proj-idx, self.text);
                        start-popup.close();
                    }
                }

                HorizontalLayout {
                    spacing: Styles.spacing;
                    alignment: end;

                    Button {
                        text: "OK";
                        clicked => {
                            PjmCallback.set_project_start_week(root.editing-start-proj-idx, start-le.text);
                            start-popup.close();
                        }
                    }

                    Button {
                        text: "Rimuovi";
                        clicked => {
                            PjmCallback.set_project_start_week(root.editing-start-proj-idx, "");
                            start-popup.close();
                        }
                    }

                    Button {
                        text: "Annulla";
                        clicked => {
                            start-popup.close();
                        }
                    }
                }
            }
        }
    }

    deadline-popup := PopupWindow {
        close-policy: no-auto-close;
        x: root.deadline-popup-x;
        y: root.deadline-popup-y;
        width: 260px;
        height: 130px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 260px;
            height: 130px;

            VerticalLayout {
                padding: Styles.padding;
                spacing: Styles.spacing;

                Text {
                    color: Colors.lightgray;
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text: "Data fine progetto (yy-mm-dd)";
                }

                deadline-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> root.editing-deadline-text;
                    placeholder-text: "yy-mm-dd";
                    accepted => {
                        PjmCallback.set_project_end_week(root.editing-proj-idx, self.text);
                        deadline-popup.close();
                    }
                }

                HorizontalLayout {
                    spacing: Styles.spacing;
                    alignment: end;

                    Button {
                        text: "OK";
                        clicked => {
                            PjmCallback.set_project_end_week(root.editing-proj-idx, deadline-le.text);
                            deadline-popup.close();
                        }
                    }

                    Button {
                        text: "Rimuovi";
                        clicked => {
                            PjmCallback.set_project_end_week(root.editing-proj-idx, "");
                            deadline-popup.close();
                        }
                    }

                    Button {
                        text: "Annulla";
                        clicked => {
                            deadline-popup.close();
                        }
                    }
                }
            }
        }
    }

    tripletta-popup := PopupWindow {
        close-policy: no-auto-close;
        x: root.tripletta-popup-x;
        y: root.tripletta-popup-y;
        width: 260px;
        height: 110px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;
            width: 260px;
            height: 110px;

            VerticalLayout {
                padding: Styles.padding;
                spacing: Styles.spacing;

                Text {
                    color: Colors.lightgray;
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text: "Tripletta";
                }

                tripletta-le := LineEdit {
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text <=> root.editing-tripletta-text;
                    placeholder-text: "Tripletta...";
                    accepted => {
                        PjmCallback.set_project_tripletta(root.editing-tripletta-proj-idx, self.text);
                        tripletta-popup.close();
                    }
                }

                HorizontalLayout {
                    spacing: Styles.spacing;
                    alignment: end;

                    Button {
                        text: "OK";
                        clicked => {
                            PjmCallback.set_project_tripletta(root.editing-tripletta-proj-idx, tripletta-le.text);
                            tripletta-popup.close();
                        }
                    }

                    Button {
                        text: "Annulla";
                        clicked => {
                            tripletta-popup.close();
                        }
                    }
                }
            }
        }
    }

    confirm-dev-popup := PopupWindow {
        close-policy: no-auto-close;
        x: 10px;
        y: 150px;
        width: 260px;
        height: 110px;

        Rectangle {
            background: #1e1e1e;
            border-color: #d9534f;
            border-width: 1px;
            width: 260px;
            height: 110px;

            VerticalLayout {
                padding: Styles.padding;
                spacing: Styles.spacing;

                Text {
                    color: Colors.lightgray;
                    font-family: Styles.font-family;
                    font-size: Styles.font-size;
                    text: "Questo dev ha già dati inseriti.\nRimuovere comunque?";
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: Styles.spacing;
                    alignment: end;

                    Button {
                        text: "Sì, rimuovi";
                        clicked => {
                            PjmCallback.add_dev_to_project(root.confirm-dev-proj, root.confirm-dev-idx, false);
                            confirm-dev-popup.close();
                        }
                    }

                    Button {
                        text: "Annulla";
                        clicked => {
                            confirm-dev-popup.close();
                        }
                    }
                }
            }
        }
    }

    category-popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: root.category-popup-x;
        y: root.category-popup-y;
        width: 150px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;

            VerticalLayout {
                padding: 2px;
                spacing: 0px;

                Rectangle {
                    height: Styles.height;
                    background: cat-none-ta.has-hover ? #3a3a3a : Colors.transparent;

                    Text {
                        text: "— Nessuna";
                        color: #888888;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }

                    cat-none-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_project_category(root.category-menu-proj-idx, -1);
                            category-popup.close();
                        }
                    }
                }

                for cat in root.app_project.categories: Rectangle {
                    height: Styles.height;
                    background: cat-item-ta.has-hover ? #3a3a3a : Colors.transparent;

                    Text {
                        text: cat.title;
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }

                    cat-item-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_project_category(root.category-menu-proj-idx, cat.id);
                            category-popup.close();
                        }
                    }
                }
            }
        }
    }

    effort-menu-popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: root.effort-menu-x;
        y: root.effort-menu-y;
        width: 160px;

        Rectangle {
            background: #1e1e1e;
            border-color: #555555;
            border-width: 1px;

            VerticalLayout {
                padding: 4px;
                spacing: 0px;

                Rectangle {
                    height: Styles.height;
                    background: show-effort-ta.has-hover ? #3a3a3a : Colors.transparent;
                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        height: parent.height;
                        text: "Visualizza effort";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    show-effort-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_dev_hide_effort(root.effort-menu-proj, root.effort-menu-dev, false);
                            effort-menu-popup.close();
                        }
                    }
                }

                Rectangle {
                    height: Styles.height;
                    background: hide-effort-ta.has-hover ? #3a3a3a : Colors.transparent;
                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        height: parent.height;
                        text: "Nascondi effort";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                        vertical-alignment: center;
                    }

                    hide-effort-ta := TouchArea {
                        clicked => {
                            PjmCallback.set_dev_hide_effort(root.effort-menu-proj, root.effort-menu-dev, true);
                            effort-menu-popup.close();
                        }
                    }
                }
            }
        }
    }

    popup := Devmenu {
        visible: false;
        request-note-edit(project, dev, current-note) => {
            PjmCallback.note-editor-project = project;
            PjmCallback.note-editor-dev = dev;
            PjmCallback.note-editor-text = current-note;
            PjmCallback.note-editor-is-dev = true;
            PjmCallback.note-editor-active = true;
        }
    }

    dev-popup := DevSelectPopup {
        devs: root.app_project.devs;
        visible: false;
        confirm-remove(proj, dev) => {
            root.confirm-dev-proj = proj;
            root.confirm-dev-idx = dev;
            confirm-dev-popup.show();
        }
    }

    Flickable {
        width: root.width;
        height: root.height;
        viewport-y <=> root.viewport_y;
        VerticalLayout {
            spacing: 0px;
            padding: 0px;
            // Per ogni progetto
            for project in root.app_project.projects: Rectangle {
                visible: project.visible && project.enable;
                height: self.visible ? self.preferred-height : 0px;
                VerticalLayout {
                    spacing: 0px;
                    padding: 0px;
                    // Casella di testo per l'info del progetto
                    // + i vari Dev
                    Rectangle {
                        // Casella di testo per l'info del progetto
                        // + i vari Dev
                        HorizontalLayout {
                            spacing: 0px;
                            padding: 0px;
                            // Casella di testo per l'info del progetto
                            // + il pulsante "+ Dev"
                            VerticalLayout {
                                spacing: 0px;
                                padding: 0px;

                                // Text {
                                //     text: "\{project.project_id}";
                                //     color: #666666;
                                //     font-family: Styles.font-family;
                                //     font-size: Styles.font-size - 2px;
                                //     horizontal-alignment: center;
                                //     height: 14px;
                                // }

                                Rectangle {
                                    height: Styles.height;

                                    TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        pointer-event(event) => {
                                            if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                                root.editing-tripletta-proj-idx = project.project_id;
                                                root.editing-tripletta-text = project.tripletta;
                                                root.tripletta-popup-x = self.absolute-position.x;
                                                root.tripletta-popup-y = self.absolute-position.y + Styles.height;
                                                tripletta-popup.show();
                                            }
                                        }
                                    }

                                    Text {
                                        text: project.tripletta != "" ? project.tripletta : "—";
                                        color: project.tripletta != "" ? Styles.effort-color : #555555;
                                        font-family: Styles.font-family;
                                        font-size: Styles.font-size;
                                        font-weight: project.tripletta != "" ? 700 : 400;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                }

                                // Category row
                                Rectangle {
                                    height: (root.visible && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                    visible: root.visible && !PjmCallback.compact-mode;
                                    background: cat-select-ta.has-hover ? #2a2a2a : Colors.transparent;

                                    cat-select-ta := TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => {
                                            root.category-menu-proj-idx = project.project_id;
                                            root.category-popup-x = self.absolute-position.x;
                                            root.category-popup-y = self.absolute-position.y + Styles.height;
                                            category-popup.show();
                                        }
                                    }

                                    Text {
                                        text: project.category_name != "" ? project.category_name : "—";
                                        color: project.category_name != "" ? #7ab0d4 : #444444;
                                        font-family: Styles.font-family;
                                        font-size: Styles.font-size;
                                        font-weight: 400;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                }

                                Rectangle {
                                    TextEdit {
                                        wrap: TextWrap.word-wrap;
                                        horizontal-alignment: center;
                                        text: project.text;
                                        width: parent.width;
                                        font-family: Styles.font-family;
                                        font-size: Styles.font-size;
                                        height: root.visible ? parent.height : 0px;

                                        edited(text) => {
                                            project.text = text;
                                            PjmCallback.changed = true;
                                            PjmCallback.set_project_name(project.project_id, text);
                                        }
                                    }
                                }

                                // Start week display row
                                Rectangle {
                                    height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;

                                    start-label-ta := TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        pointer-event(event) => {
                                            if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                                root.editing-start-proj-idx = project.project_id;
                                                root.editing-start-text = project.start_text;
                                                root.start-popup-x = self.absolute-position.x;
                                                root.start-popup-y = self.absolute-position.y + Styles.height;
                                                start-popup.show();
                                            }
                                        }
                                    }

                                    Text {
                                        height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                        font-family: Styles.font-family;
                                        font-size: Styles.font-size - 2px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        text: project.start_week >= 0 ? "Inizio: " + project.start_text : "Inizio: —";
                                    }
                                }

                                // Deadline display row
                                Rectangle {
                                    height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                    //background: project.end_week >= 0 ? #00440020 : Colors.transparent;

                                    deadline-label-ta := TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        pointer-event(event) => {
                                            if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                                root.editing-proj-idx = project.project_id;
                                                root.editing-deadline-text = project.deadline_text;
                                                root.deadline-popup-x = self.absolute-position.x;
                                                root.deadline-popup-y = self.absolute-position.y + Styles.height;
                                                deadline-popup.show();
                                            }
                                        }
                                    }

                                    Text {
                                        height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                        font-family: Styles.font-family;
                                        font-size: Styles.font-size - 2px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        text: project.end_week >= 0 ? "Fine: " + project.deadline_text : "Fine: —";
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 0px;
                                    padding: 0px;

                                    add-dev-btn := Rectangle {
                                        height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                        background: add-dev-ta.has-hover ? #3a3a3a : #2a2a2a;
                                        border-color: #555;
                                        border-width: 1px;

                                        Text {
                                            text: "+ Dev";
                                            color: Colors.lightgray;
                                            font-size: Styles.font-size;
                                            font-family: Styles.font-family;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            height: parent.height;
                                        }

                                        add-dev-ta := TouchArea {
                                            height: parent.height;
                                            width: parent.width;
                                            visible: root.visible && !PjmCallback.filter_active;
                                            clicked => {
                                                dev-popup.x = add-dev-btn.absolute-position.x;
                                                dev-popup.y = add-dev-btn.absolute-position.y + add-dev-btn.height;
                                                dev-popup.show(project.project_id, true, project.dev_in_project, project.dev_has_data);
                                            }
                                        }
                                    }

                                    del-dev-btn := Rectangle {
                                        height: (root.visible && !PjmCallback.filter_active && !PjmCallback.compact-mode) ? Styles.height : 0px;
                                        background: del-dev-ta.has-hover ? #3a3a3a : #2a2a2a;
                                        border-color: #555;
                                        border-width: 1px;

                                        Text {
                                            text: "- Dev";
                                            color: Colors.lightgray;
                                            font-size: Styles.font-size;
                                            font-family: Styles.font-family;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            height: parent.height;
                                        }

                                        del-dev-ta := TouchArea {
                                            height: parent.height;
                                            width: parent.width;
                                            visible: root.visible && !PjmCallback.filter_active;

                                            clicked => {
                                                dev-popup.x = del-dev-btn.absolute-position.x;
                                                dev-popup.y = del-dev-btn.absolute-position.y + del-dev-btn.height;
                                                dev-popup.show(project.project_id, false, project.dev_in_project, project.dev_has_data);
                                            }
                                        }
                                    }
                                }
                            }

                            // I vari dev collegati al progetto
                            VerticalLayout {
                                spacing: 0px;
                                padding: 0px;
                                for data in project.devs-of-the-project: Rectangle {
                                    property <bool> visibility;
                                    visibility: data.visible;

                                    // I vari dev collegati al progetto
                                    VerticalLayout {
                                        spacing: 0px;
                                        padding: 0px;
                                        Separatore {
                                            bgcolor: root.app_project.devs[data.dev].col;
                                            height: visibility ? Styles.dev-border : 0px;
                                        }

                                        Rectangle {
                                            height: visibility ? (PjmCallback.compact-mode ? Styles.height : Styles.height * (data.max + 1)) : 0px;

                                            HorizontalLayout {
                                                spacing: 0px;
                                                padding: 0px;
                                                // Text Dev1 or Dev2, ...
                                                dev-rect := Rectangle {
                                                    background: root.app_project.devs[data.dev].col;
                                                    width: Styles.width;
                                                    clip: true;
                                                    Text {
                                                        width: Styles.width - 10px;
                                                        font-weight: 800;
                                                        color: root.app_project.devs[data.dev].text-color;
                                                        text: root.app_project.devs[data.dev].title;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                        wrap: word-wrap;
                                                        cell := TouchArea {
                                                            width: dev-rect.width;
                                                            height: dev-rect.height;
                                                            double-clicked => {
                                                                debug("add_row");
                                                                PjmCallback.add_row(project.project_id, data.dev);
                                                            }

                                                            pointer-event(event) => {
                                                                if event.button == PointerEventButton.right {
                                                                    if event.kind == PointerEventKind.down {
                                                                        popup.x = self.absolute-position.x;
                                                                        popup.y = self.absolute-position.y - 50px;
                                                                        popup.visible = true;
                                                                        popup.show(project.project_id, data.dev, !data.enable, data.note);
                                                                    } else {
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }

                                                    note-indicator := Rectangle {
                                                        x: parent.width - 10px;
                                                        y: 0px;
                                                        width: data.note != "" ? 10px : 0px;
                                                        height: data.note != "" ? 10px : 0px;
                                                        clip: false;
                                                        background: Colors.transparent;

                                                        if data.note != "": CornerTriangle { }

                                                        if data.note != "": TouchArea {
                                                            width: 10px;
                                                            height: 10px;
                                                            changed has-hover => {
                                                                if self.has-hover {
                                                                    PjmCallback.note-popup-text = data.note;
                                                                    PjmCallback.note-popup-x = self.absolute-position.x - 140px;
                                                                    PjmCallback.note-popup-y = self.absolute-position.y + 11px;
                                                                    PjmCallback.note-popup-visible = true;
                                                                } else {
                                                                    PjmCallback.note-popup-visible = false;
                                                                }
                                                            }
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    height: visibility ? (PjmCallback.compact-mode ? Styles.height : Styles.height * (data.max + 1)) : 0px;
                                                    background: root.app_project.devs[data.dev].col;
                                                    width: Styles.width - 25px;
                                                    VerticalLayout {
                                                        spacing: 0px;
                                                        padding: 0px;
                                                        LineEdit {
                                                            horizontal-alignment: center;
                                                            text: data.effort;
                                                            height: visibility && !PjmCallback.compact-mode ? Styles.height : 0px;

                                                            key-pressed(event) => {
                                                                if event.text == Key.Tab {
                                                                    data.effort = self.text.to-float();
                                                                    PjmCallback.set_dev_effort(project.project_id, data.dev, self.text.to-float());
                                                                    return accept;
                                                                }
                                                                reject
                                                            }
                                                            accepted(text) => {
                                                                data.effort = text.to-float();
                                                                PjmCallback.set_dev_effort(project.project_id, data.dev, text.to-float());
                                                            }
                                                        }

                                                        remains := Rectangle {
                                                            background: ((data.remains == data.effort && data.effort != 0) || (data.remains < 0)) ? Colors.red : Colors.transparent;
                                                            height: visibility && !PjmCallback.compact-mode ? self.preferred-height : 0px;
                                                            Text {
                                                                height: parent.height;
                                                                horizontal-alignment: center;
                                                                vertical-alignment: center;
                                                                text: data.remains;
                                                            }

                                                            TouchArea {
                                                                pointer-event(event) => {
                                                                    if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                                                        root.effort-menu-proj = project.project_id;
                                                                        root.effort-menu-dev = data.dev;
                                                                        root.effort-menu-x = self.absolute-position.x;
                                                                        root.effort-menu-y = self.absolute-position.y + self.height;
                                                                        effort-menu-popup.show();
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        Separatore {
                                            height: visibility ? Styles.dev-border : 0px;
                                            bgcolor: root.app_project.devs[data.dev].col;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: root.visible ? Styles.dev-border : 0px;
                        background: Styles.color-between-projects;
                    }
                }
            }
        }
    }
}
