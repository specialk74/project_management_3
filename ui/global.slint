import {
    Button,
    VerticalBox,
    ListView,
    CheckBox,
    LineEdit,
    Spinner,
    TextEdit,
    HorizontalBox,
    ProgressIndicator,
    StyleMetrics,
    Palette,
} from "std-widgets.slint";

import { Styles } from "styles.slint";

export struct DevInfo {
    title: string,
    col: color,
    text-color: color,
}

export struct SingleEffortGui {
    week: int,
    dev: int,
    project: int,
    effort: int,
    name: string,
    note: string,
    sovra: int,
    max_hours: int,
    hidden_by_filter: bool,
}

export struct EffortByDateData {
    total: int,
    cumulative: int,
    remains: int,
    dev: int,
    project: int,
    effort: int,
    week: int,
    has_workers: bool,
    persons: [SingleEffortGui],
}

export struct EffortByDevData {
    project: int,
    dev: int,
    total: int,
    effort: int,
    remains: int,
    visible: bool,
    enable: bool,
    max: int,
    note: string,
    start_week: int,
    deadline_week: int,
    hide_effort: bool,
    activity_start: int,
    activity_end: int,
    datas: [EffortByDateData],
}

export struct EffortByPrjData {
    project_id: int,
    text: string,
    tripletta: string,
    start_week: int,
    start_text: string,
    end_week: int,
    deadline_text: string,
    visible: bool,
    enable: bool,
    devs_of_the_project: [EffortByDevData],
    dev_in_project: [bool],
    dev_has_data: [bool],
}

export struct SovraData {
    value: [int],
    max_hours: [int],
    week: int,
}

export struct AppProject {
    worker_names: [string],
    worker_max_hours: [int],
    worker_filter_selected: [bool],
    week_off: [int],
    sovra: [SovraData],
    projects: [EffortByPrjData],
    devs: [DevInfo],
    years: [int],
    dev_year_totals: [int],
}

export struct DayData {
    week: int,
    text: string,
    all_limited: bool,
}

export struct ProjectListItem {
    text: string,
    visible: bool,
}

export global PjmCallback {
    callback changed_effort(EffortByDateData);
    callback set_dev_effort(int /*project*/, int /*dev*/, int /*effort*/);
    callback save_file();
    callback open_file();
    callback search(string);
    callback set_worker_filter(int /*worker_idx*/, bool /*selected*/);
    callback set_all_workers_filter(bool /*selected*/);
    callback new_project(string /*tripletta*/, string /*name*/, string /*start_date_yy_mm_dd*/);
    callback set_project_start_week(int /*project_idx*/, string /*date_str*/);
    callback set_selected_year(int /*year*/);
    in property <int> selected_year: 0;
    callback set_project_end_week(int /*project_idx*/, string /*date_str*/);
    callback add_row(int, int);
    callback del_row(int, int);
    callback hide_dev(int, int, bool);
    callback add_worker(string);
    callback add_dev(string);
    callback add_dev_to_project(int /*project*/, int /*dev*/, bool /*add*/);
    callback set_project_name(int /*project_idx*/, string);
    callback set_project_tripletta(int /*project_idx*/, string);
    callback find_completion(string, bool) -> string;
    callback remove_last_char(string) -> string;
    in property <string> current-week-text: "";
    in property <string> testo-copiato;
    in-out property <bool> show-worker-filter: false;
    in property <bool> all_workers_filter_on: false;
    in property <bool> all_workers_filter_off: true;
    in property <bool> changed;
    in property <int> this_week;
    in property <length> this_week_width: 5px;
    in property <string> current_file: "efforts.json";
    // Selezione
    in-out property <int> sel_project: -1;
    in-out property <int> sel_dev: -1;
    in-out property <int> sel_anchor_week: -1;
    in-out property <int> sel_anchor_row: -1;
    in-out property <int> sel_start_week: -1;
    in-out property <int> sel_end_week: -1;
    in-out property <int> sel_start_row: -1;
    in-out property <int> sel_end_row: -1;
    // Note popup (gestito a livello AppWindow)
    in-out property <bool> note-popup-visible: false;
    in-out property <string> note-popup-text: "";
    in-out property <length> note-popup-x: 0px;
    in-out property <length> note-popup-y: 0px;
    // Note editor callbacks
    callback set_note(int /*project*/, int /*dev*/, int /*week*/, string /*person_name_effort*/, string /*note*/);
    callback set_dev_note(int /*project*/, int /*dev*/, string /*note*/);
    // Worker max hours callbacks
    callback set_worker_max_hours(int /*worker_idx*/, string /*hours_text*/);
    callback set_worker_week_override(int /*worker_idx*/, int /*week*/, string /*hours_text*/);
    callback set_bulk_week_limit(int /*week*/, string /*hours_text*/);
    callback set_project_enabled(int /*project_id*/, bool /*enabled*/);
    callback set_all_projects_enabled(bool /*enabled*/);
    in property <bool> all_projects_enabled: false;
    in property <bool> all_projects_disabled: false;
    callback set_dev_hide_effort(int /*project*/, int /*dev*/, bool /*hide*/);
    in property <bool> filter_active: false;
    // 0 = tutti gli effort, 1 = solo nulli, 2 = solo >= 40
    in-out property <int> effort-filter-mode: 0;
    in-out property <bool> compact-mode: false;
    // Floating cell editor
    in-out property <bool> editor-active: false;
    in-out property <length> editor-x: 0px;
    in-out property <length> editor-y: 0px;
    in-out property <string> editor-text: "";
    in-out property <string> editor-typed-prefix: "";
    in-out property <int> editor-project: -1;
    in-out property <int> editor-dev: -1;
    in-out property <int> editor-week: -1;
    in-out property <int> editor-row: -1;
    in-out property <EffortByDateData> editor-effort;
    callback editor-accept();
    // Note editor globale
    in-out property <bool> note-editor-active: false;
    in-out property <bool> note-editor-is-dev: false;
    in-out property <int> note-editor-project: -1;
    in-out property <int> note-editor-dev: -1;
    in-out property <int> note-editor-week: -1;
    in-out property <string> note-editor-worker: "";
    in-out property <string> note-editor-text: "";
    // Ticker globale per l'animazione marquee di Cell-RO
    in-out property <int> marquee-tick: 0;
}

export component NoteEditorWindow inherits Window {
    in-out property <string> note-text: "";
    property <bool> is-dev: false;
    property <int> edit-project: -1;
    property <int> edit-dev: -1;
    property <int> edit-week: -1;
    property <string> edit-worker: "";
    in property <length> container-width: 1024px;
    in property <length> container-height: 768px;

    public function show-for-effort(project: int, dev: int, week: int, worker: string, current-note: string) {
        edit-project = project;
        edit-dev = dev;
        edit-week = week;
        edit-worker = worker;
        is-dev = false;
        note-text = current-note;
        popup.show();
    }

    public function show-for-dev(project: int, dev: int, current-note: string) {
        edit-project = project;
        edit-dev = dev;
        is-dev = true;
        note-text = current-note;
        popup.show();
    }

    popup := PopupWindow {
        close-policy: close-on-click-outside;
        width: 320px;
        x: (root.container-width - self.width) / 2;
        y: (root.container-height - self.height) / 2;

        FocusScope {
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    popup.close();
                    return accept;
                }
                reject
            }

            Rectangle {
                background: #1e1e1e;
                border-color: #555555;
                border-width: 1px;

                VerticalLayout {
                    padding: Styles.padding;
                    spacing: Styles.spacing;

                    Text {
                        text: is-dev ? "Nota Dev:" : "Nota:";
                        color: Colors.lightgray;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                    }

                    note-te := TextEdit {
                        text <=> note-text;
                        width: 300px;
                        height: 120px;
                        font-family: Styles.font-family;
                        font-size: Styles.font-size;
                    }

                    HorizontalLayout {
                        spacing: Styles.spacing;
                        alignment: end;

                        Button {
                            text: "Salva";
                            clicked => {
                                if (is-dev) {
                                    PjmCallback.set_dev_note(edit-project, edit-dev, note-text);
                                } else {
                                    PjmCallback.set_note(edit-project, edit-dev, edit-week, edit-worker, note-text);
                                }
                                popup.close();
                            }
                        }

                        Button {
                            text: "Annulla";
                            clicked => {
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

component InternalText inherits Text {
    overflow: clip;
    vertical-alignment: center;
    horizontal-alignment: center;
    wrap: word-wrap;
}

export component CornerTriangle inherits Rectangle {
    background: transparent;

    Path {
        x: parent.width - 10px;
        y: 0px;
        width: 10px;
        height: 10px;
        fill: Styles.effort-color;
        MoveTo {
            x: 10;
            y: 0;
        }

        LineTo {
            x: 10;
            y: 10;
        }

        LineTo {
            x: 0;
            y: 0;
        }

        Close { }
    }
}

export component Cell-RO inherits Rectangle {
    in property <string> text;
    in property <color> text_color: Palette.color-scheme == ColorScheme.dark ? Colors.white : Colors.black;
    in property <int> font-weight: 800;
    //in property <color> error_color: #ffffff;
    //in property <color> background_color: #ffffff;
    in property <TextHorizontalAlignment> horizontal-alignment: TextHorizontalAlignment.center;

    height: self.visible ? Styles.height : 0px;
    width: Styles.width;
    //background: root.error_color;

    clip: true;
    Rectangle {
        width: parent.width - 5px; // Sennò le scritte si sovrappongono
        //height: self.visible ? parent.height - 5px : 0px;

        innerRect := Rectangle {
            property <bool> overflowing: self.width > parent.width;
            property <bool> at-start: true;
            x: overflowing ? (at-start ? 0px : (parent.width - self.width)) : (parent.width - self.width) / 2;
            width: myText.width;
            animate x {
                duration: 1000ms;
                easing: ease-in-out;
            }

            property <int> _tick: PjmCallback.marquee-tick;
            changed _tick => {
                if (overflowing) {
                    at-start = !at-start;
                }
            }

            myText := InternalText {
                color: root.text_color;
                text: root.text;
                font-weight: root.font-weight;
                horizontal-alignment: root.horizontal-alignment;
            }
        }
    }
}

export component Cell-RW inherits Rectangle {
    in-out property <string> text;
    in property <string> note;
    in property <bool> selected: false;
    in property <color> text-color;
    in property <int> cell-project: -1;
    in property <int> cell-dev: -1;
    in property <int> cell-week: -1;
    in property <int> cell-row: -1;
    callback double_clicked(string);
    // Selezione
    callback sel_plain();
    callback sel_shift();
    callback sel_ctrl();
    // Note
    callback edit_note();
    // Richiesta apertura floating editor: (abs-x, abs-y, testo-corrente, typed-prefix)
    callback request-edit(length, length, string, string);

    property <bool> editing: PjmCallback.editor-active && PjmCallback.editor-project == cell-project && PjmCallback.editor-dev == cell-dev && PjmCallback.editor-week == cell-week && PjmCallback.editor-row == cell-row;
    property <bool> has-focus: fs.has-focus;
    property <string> typed_prefix: "";
    height: self.visible ? Styles.height : 0px;
    width: Styles.width;

    fs := FocusScope {
        focus-on-tab-navigation: true;

        Rectangle {
            visible: !editing;
            background: fs.has-focus ? Colors.steelblue.with-alpha(0.35) : Colors.transparent;
            border-color: fs.has-focus ? Colors.orangered : Colors.transparent;
            border-width: parent.visible ? 1px : 0px;

            TouchArea {
                mouse-cursor: default;

                pointer-event(event) => {
                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                        if event.modifiers.shift {
                            root.sel_shift();
                        } else if event.modifiers.control {
                            root.sel_ctrl();
                        } else {
                            root.sel_plain();
                            fs.focus();
                        }
                    }
                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                        if root.text != "" {
                            root.edit_note();
                        }
                    }
                }

                Cell-RO {
                    text: root.text;
                    text_color: root.text-color;
                    font-weight: 100;
                }
            }
        }

        key-pressed(event) => {
            if (event.modifiers.control) {
                if (event.text == "C" || event.text == "c") {
                    PjmCallback.testo-copiato = root.text;
                }
                if (event.text == "V" || event.text == "v") {
                    root.text = PjmCallback.testo-copiato;
                    root.double_clicked(root.text);
                }
                if (event.text == "S" || event.text == "s") {
                    PjmCallback.save_file();
                    return accept;
                }
                if (event.text == "f") {
                    PjmCallback.show-worker-filter = true;
                    return accept;
                }
                if (event.text == "F") {
                    PjmCallback.set_all_workers_filter(false);
                    return accept;
                }
                if (event.text == "m" || event.text == "M") {
                    if (root.text != "") {
                        root.edit_note();
                    }
                    return accept;
                }
            }
            if (event.text == Key.Escape) {
                PjmCallback.editor-active = false;
            }
            if (event.text == Key.Return) {
                typed_prefix = root.text;
                root.request-edit(fs.absolute-position.x, fs.absolute-position.y, root.text, typed_prefix);
            }
            if (event.text == Key.Delete || event.text == Key.Backspace) {
                root.text = "";
                typed_prefix = "";
                root.double_clicked(root.text);
            }
            // Typing any printable character enters edit mode immediately (like Excel)
            if (!root.editing && !event.modifiers.control && !event.modifiers.alt && !event.modifiers.meta && event.text != "" && event.text != Key.Escape && event.text != Key.Return && event.text != Key.Tab && event.text != Key.Shift && event.text != Key.ShiftR && event.text != Key.Delete && event.text != Key.Backspace && event.text != Key.UpArrow && event.text != Key.DownArrow && event.text != Key.LeftArrow && event.text != Key.RightArrow) {
                typed_prefix = event.text;
                root.text = PjmCallback.find_completion(event.text, true);
                if root.text == "" {
                    root.text = typed_prefix;
                } else {
                    typed_prefix = root.text;
                }
                root.request-edit(fs.absolute-position.x, fs.absolute-position.y, root.text, typed_prefix);
                return accept;
            }
            if (event.text == Key.Tab) {
                reject
            } else {
                accept
            }
        }
    }

    note-indicator := Rectangle {
        x: parent.width - 10px;
        y: 0px;
        width: root.note != "" ? 10px : 0px;
        height: root.note != "" ? 10px : 0px;
        clip: false;
        background: Colors.transparent;

        if root.note != "": CornerTriangle { }

        if root.note != "": TouchArea {
            width: 10px;
            height: 10px;
            changed has-hover => {
                if self.has-hover {
                    PjmCallback.note-popup-text = root.note;
                    PjmCallback.note-popup-x = self.absolute-position.x - 140px;
                    PjmCallback.note-popup-y = self.absolute-position.y + 11px;
                    PjmCallback.note-popup-visible = true;
                } else {
                    PjmCallback.note-popup-visible = false;
                }
            }
        }
    }
}

export component EffortByDataGui inherits Rectangle {
    in property <EffortByDateData> effort;
    in property <bool> after-deadline: false;
    in property <bool> before-start: false;
    in property <bool> hide-effort: false;
    in property <bool> is-deadline: false;
    in property <color> dev-color: Colors.transparent;
    in property <bool> dev-in-activity: false;

    width: PjmCallback.compact-mode ? Styles.compact : Styles.width;

    VerticalLayout {
        spacing: 0px;
        padding: 0px;

        function my-function(effort: EffortByDateData) -> color {
            if effort.total == 0 {
                return Palette.color-scheme == ColorScheme.dark ? Colors.white : Colors.black;
            }
            if effort.total < effort.effort * 10 / 100 {
                return #018730;
            }
            if effort.total < effort.effort * 20 / 100 {
                return #558d00;
            }
            if effort.total < effort.effort * 30 / 100 {
                return #6d8800;
            }
            if effort.total < effort.effort * 40 / 100 {
                return #888800;
            }
            if effort.total < effort.effort * 50 / 100 {
                return #a88700;
            }
            if effort.total < effort.effort * 60 / 100 {
                return #b57a00;
            }
            if effort.total < effort.effort * 70 / 100 {
                return #cf6f00;
            }
            if effort.total < effort.effort * 80 / 100 {
                return #c54300;
            }
            if effort.total < effort.effort * 90 / 100 {
                return #d52c00;
            }
            return #d10100;
        }

        cell := Cell-RO {
            visible: !PjmCallback.compact-mode && root.visible && !root.after-deadline && !root.before-start && (root.effort.has_workers || root.is-deadline);
            text: root.hide-effort ? "" : (effort.cumulative != (effort.effort - effort.cumulative) ? "\{effort.cumulative} | \{effort.effort - effort.cumulative}" : "\{effort.effort - effort.cumulative}");
            text_color: root.is-deadline ? Colors.white : my-function(effort);

            t := TouchArea {
                width: parent.width;
                height: parent.height;
            }
        }

        for person[row_idx] in effort.persons: Cell-RW {
            text: person.name;
            note: person.note;
            visible: !PjmCallback.compact-mode && root.visible && !root.after-deadline && !root.before-start && !person.hidden_by_filter;
            text-color: (person.name != "" && person.sovra > person.max_hours) ? Colors.red : (Palette.color-scheme == ColorScheme.dark ? Colors.white : Colors.black);
            selected: effort.project == PjmCallback.sel_project && effort.dev == PjmCallback.sel_dev && effort.week >= PjmCallback.sel_start_week && effort.week <= PjmCallback.sel_end_week && row_idx >= PjmCallback.sel_start_row && row_idx <= PjmCallback.sel_end_row;
            cell-project: effort.project;
            cell-dev: effort.dev;
            cell-week: effort.week;
            cell-row: row_idx;

            request-edit(ax, ay, text, tp) => {
                PjmCallback.editor-project = effort.project;
                PjmCallback.editor-dev = effort.dev;
                PjmCallback.editor-week = effort.week;
                PjmCallback.editor-row = row_idx;
                PjmCallback.editor-effort = root.effort;
                PjmCallback.editor-text = text;
                PjmCallback.editor-typed-prefix = tp;
                PjmCallback.editor-x = ax;
                PjmCallback.editor-y = ay;
                PjmCallback.editor-active = true;
            }

            double_clicked(text) => {
                person.name = text;
                PjmCallback.changed_effort(root.effort);
            }

            edit_note() => {
                PjmCallback.note-editor-project = effort.project;
                PjmCallback.note-editor-dev = effort.dev;
                PjmCallback.note-editor-week = effort.week;
                PjmCallback.note-editor-worker = person.name;
                PjmCallback.note-editor-text = person.note;
                PjmCallback.note-editor-is-dev = false;
                PjmCallback.note-editor-active = true;
            }

            sel_plain() => {
                PjmCallback.sel_project = effort.project;
                PjmCallback.sel_dev = effort.dev;
                PjmCallback.sel_anchor_week = effort.week;
                PjmCallback.sel_anchor_row = row_idx;
                PjmCallback.sel_start_week = effort.week;
                PjmCallback.sel_end_week = effort.week;
                PjmCallback.sel_start_row = row_idx;
                PjmCallback.sel_end_row = row_idx;
            }

            sel_shift() => {
                if effort.project == PjmCallback.sel_project && effort.dev == PjmCallback.sel_dev {
                    PjmCallback.sel_start_week = min(effort.week, PjmCallback.sel_anchor_week);
                    PjmCallback.sel_end_week = max(effort.week, PjmCallback.sel_anchor_week);
                    PjmCallback.sel_start_row = min(row_idx,     PjmCallback.sel_anchor_row);
                    PjmCallback.sel_end_row = max(row_idx,     PjmCallback.sel_anchor_row);
                }
            }

            sel_ctrl() => {
                if effort.project == PjmCallback.sel_project && effort.dev == PjmCallback.sel_dev {
                    if effort.week < PjmCallback.sel_start_week {
                        PjmCallback.sel_start_week = effort.week;
                    }
                    if effort.week > PjmCallback.sel_end_week {
                        PjmCallback.sel_end_week = effort.week;
                    }
                    if row_idx < PjmCallback.sel_start_row {
                        PjmCallback.sel_start_row = row_idx;
                    }
                    if row_idx > PjmCallback.sel_end_row {
                        PjmCallback.sel_end_row = row_idx;
                    }
                } else {
                    PjmCallback.sel_project = effort.project;
                    PjmCallback.sel_dev = effort.dev;
                    PjmCallback.sel_anchor_week = effort.week;
                    PjmCallback.sel_anchor_row = row_idx;
                    PjmCallback.sel_start_week = effort.week;
                    PjmCallback.sel_end_week = effort.week;
                    PjmCallback.sel_start_row = row_idx;
                    PjmCallback.sel_end_row = row_idx;
                }
            }
        }

        if PjmCallback.compact-mode && root.visible && !root.after-deadline && !root.before-start && root.dev-in-activity: Rectangle {
            width: Styles.compact;
            height: Styles.height;
            Rectangle {
                property <float> ratio: min(1.0, root.effort.total / 40.0);
                width: parent.width;
                height: root.effort.total == 0 ? 1px : max(1px, Styles.height * ratio);
                y: parent.height - self.height;
                background: root.dev-color;
            }
        }
    }
}

export component EffortByDevGui inherits Rectangle {
    in property <EffortByDevData> datas;
    in property <[DevInfo]> devs;
    visible: datas.visible && datas.enable;
    VerticalLayout {
        Rectangle {
            height: root.visible ? Styles.dev-border : 0px;
            background: PjmCallback.compact-mode ? Colors.transparent : root.devs[root.datas.dev].col;
        }

        HorizontalLayout {
            spacing: 0px;
            padding: 0px;

            for data in datas.datas: Rectangle {
                background: datas.deadline_week >= 0 && data.week == datas.deadline_week ? Colors.green : datas.start_week >= 0 && data.week == datas.start_week ? Colors.steelblue : Colors.transparent;
                HorizontalLayout {
                    Rectangle {
                        background: !PjmCallback.compact-mode && data.week == PjmCallback.this_week ? Styles.this-week-color : Colors.transparent;
                        width: !PjmCallback.compact-mode && data.week == PjmCallback.this_week ? PjmCallback.this_week_width : 0px;
                    }

                    EffortByDataGui {
                        effort: data;
                        visible: root.visible;
                        after-deadline: datas.deadline_week >= 0 && data.week > datas.deadline_week;
                        before-start: datas.start_week >= 0 && data.week < datas.start_week;
                        hide-effort: datas.hide_effort;
                        is-deadline: datas.deadline_week >= 0 && data.week == datas.deadline_week;
                        dev-color: root.devs[root.datas.dev].col;
                        dev-in-activity: datas.activity_start >= 0 && data.week >= datas.activity_start && datas.activity_end >= 0 && data.week <= datas.activity_end;
                    }
                }
            }
        }

        Rectangle {
            height: root.visible ? Styles.dev-border : 0px;
            background: PjmCallback.compact-mode ? Colors.transparent : root.devs[root.datas.dev].col;
        }
    }
}

export component EffortByPrjGui inherits Rectangle {
    in property <EffortByPrjData> project;
    in property <[DevInfo]> devs;
    visible: project.visible && project.enable;
    VerticalLayout {
        spacing: 0px;
        padding: 0px;

        for data in project.devs-of-the-project: EffortByDevGui {
            datas: data;
            devs: root.devs;
        }
        Rectangle {
            height: root.visible ? Styles.dev-border : 0px;
            background: Styles.color-between-projects;
        }
    }
}
